# =============================================================================
# GoGoFresh Attendance — Frontend Production Environment Template
# =============================================================================
# IMPORTANT: `NEXT_PUBLIC_*` vars are baked into the JS bundle at build time
# (`npm run build`), not at runtime. If you change either value below you MUST
# rebuild the frontend image. Pass this file via `--env-file` to the build
# step (or set the variables in your CI build environment).
# =============================================================================

# Public URL prefix the browser uses to reach the backend API. With the
# www.gogoffcc.com upstream proxy stripping /gogoffcc-arms before forwarding
# /api/* to the backend, set this to the prefix itself (NOT including /api).
# The api client code already appends `/api/...` to every request.
#   - Browser fetches: /gogoffcc-arms/api/auth/login
#   - Upstream strips: /api/auth/login
#   - Backend receives: /api/auth/login  ✓
# For a domain-root deployment, leave blank (same-origin relative paths).
NEXT_PUBLIC_API_URL=/gogoffcc-arms

# Path prefix the app is served under. Must match the backend ROOT_PATH and
# the upstream proxy's location prefix. Leave empty for domain-root deploys.
# Next.js bakes this into the client bundle — rebuild is required to change.
NEXT_PUBLIC_BASE_PATH=/gogoffcc-arms
