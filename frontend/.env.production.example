# =============================================================================
# GoGoFresh Attendance — Frontend Production Environment Template
# =============================================================================
# IMPORTANT: `NEXT_PUBLIC_*` vars are baked into the JS bundle at build time
# (`npm run build`), not at runtime. If you change this value you MUST rebuild
# the frontend image. Pass this file to `--env-file` during the build step.
# =============================================================================

# Public URL of the backend API as seen from end-user browsers.
# Use same-origin (leave blank + proxy /api through your reverse proxy) OR an
# absolute HTTPS URL. HTTP is not acceptable in production (breaks WebAuthn and
# leaks JWTs).
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
