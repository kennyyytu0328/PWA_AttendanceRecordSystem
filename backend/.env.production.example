# =============================================================================
# GoGoFresh Attendance — Backend Production Environment Template
# =============================================================================
# Copy to `.env` on the production host (or inject via your deploy system).
# NEVER commit the real `.env` — only this `.example` template.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Production default: the bundled `db` container from docker-compose.prod.yml.
# Host is the compose service name `db`. The password here MUST match
# POSTGRES_PASSWORD in the repo-root .env (the db container creates the role
# with that password on first start). Generate with: openssl rand -hex 24
# (hex only — no characters that need URL-encoding).
# If you reuse a host Postgres instead, change the host to
# host.docker.internal:5432 (see the alternative block in docker-compose.prod.yml).
DATABASE_URL=postgresql+asyncpg://attendance_user:REPLACE_WITH_STRONG_PASSWORD@db:5432/attendance

# -----------------------------------------------------------------------------
# JWT signing
# -----------------------------------------------------------------------------
# Generate with:  openssl rand -hex 32
# Must be 32+ bytes of entropy. Rotating this invalidates all active sessions.
SECRET_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Same-origin deployment (frontend and API on the same host via the upstream
# reverse proxy) → CORS is not strictly required. Leave the list with the
# public origin for safety in case any tooling makes cross-origin calls.
# Do NOT include the dev LAN regex in production.
CORS_ORIGINS=["https://www.gogoffcc.com"]
# Leave CORS_ORIGIN_REGEX unset in production (no LAN/wildcard allowance).
# CORS_ORIGIN_REGEX=

# -----------------------------------------------------------------------------
# Reverse proxy / path prefix
# -----------------------------------------------------------------------------
# Set when the app is served under a sub-path by an upstream proxy that strips
# the prefix before forwarding (e.g. www.gogoffcc.com/gogoffcc-arms strips
# /gogoffcc-arms for /api/* calls). Tells FastAPI to generate Swagger/OpenAPI
# URLs under the prefix so /docs links work from the browser. Leave empty when
# deploying at the domain root.
ROOT_PATH=/gogoffcc-arms

# -----------------------------------------------------------------------------
# WebAuthn / Fingerprint login
# -----------------------------------------------------------------------------
# RP_ID is the bare registrable domain (no scheme, no port, no path).
# ORIGIN must be https:// in production — browsers reject WebAuthn over HTTP
# for any origin other than localhost. The PATH is NOT part of either value —
# WebAuthn binds credentials to the origin (scheme + host), independent of the
# sub-path the app is served from.
WEBAUTHN_RP_ID=www.gogoffcc.com
WEBAUTHN_RP_NAME=GoGoFresh Attendance
WEBAUTHN_ORIGIN=https://www.gogoffcc.com
